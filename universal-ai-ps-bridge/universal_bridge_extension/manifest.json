{
  "manifest_version": 3,
  "name": "Universal PowerShell AI Bridge",
  "version": "1.0",
  "description": "Learning Clipboard Bridge for any AI Chat interface",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://*.bing.com/*",
        "https://chat.deepseek.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}